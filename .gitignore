# Secrets — never commit these
.env
keys/*.pem
keys/*.key

# Python virtual environment
.venv/
venv/
env/

# Python cache — generated automatically, not source code
__pycache__/
*.py[cod]
*.pyo

# pytest cache
.pytest_cache/

# SQLite database files (dev only)
*.db
*.sqlite3

# OS noise
.DS_Store
Thumbs.db

# VS Code workspace settings (optional — remove if you want to share these)
.vscode/
